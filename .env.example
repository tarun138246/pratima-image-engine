# ─────────────────────────────────────────────────────────────────────────────
#  Pratima Image Engine — Environment Configuration
#  Copy this file to .env and fill in the values for your environment.
#  The daemon reads these at startup — restart the service after any change.
# ─────────────────────────────────────────────────────────────────────────────


# ── Runtime ───────────────────────────────────────────────────────────────────

# Set to "production" to disable console logging and enable optimised behaviour
NODE_ENV=production

# Log level: error | warn | info | debug
LOG_LEVEL=info


# ── HTTP Server ───────────────────────────────────────────────────────────────

# Port the HTTP daemon listens on.
# When running behind nginx, keep this on 127.0.0.1 (localhost only).
PRATIMA_PORT=3001
PRATIMA_HOST=127.0.0.1


# ── HTTPS Server (optional — skip if nginx handles TLS) ──────────────────────
#
# Uncomment and fill in both CERT and KEY to enable a built-in HTTPS server.
# Leave commented if nginx is terminating TLS (recommended for most VPS setups).
#
# PRATIMA_TLS_CERT=/etc/letsencrypt/live/img.yourdomain.com/fullchain.pem
# PRATIMA_TLS_KEY=/etc/letsencrypt/live/img.yourdomain.com/privkey.pem
# PRATIMA_HTTPS_PORT=3443
# PRATIMA_HTTPS_HOST=0.0.0.0


# ── ClamAV ────────────────────────────────────────────────────────────────────

# Set to 1 to allow uploads even when the ClamAV daemon is unavailable.
# Default (0) = fail-closed: uploads are rejected when ClamAV is unreachable.
# Only set to 1 if you have an alternative scanning strategy in place.
PRATIMA_CLAMAV_OPTIONAL=0
